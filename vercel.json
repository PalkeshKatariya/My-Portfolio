{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/public/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/public/admin.html"
    }
  ]
}
