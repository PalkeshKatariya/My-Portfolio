{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "portfolio.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/uploads/(.*)", "dest": "/public/uploads/$1" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|webp|mp4|webm))", "dest": "/public/$1" },
    { "src": "/", "dest": "/portfolio.html" }
  ]
}
